## Copy to .env.local and fill values (do not commit .env.local)
## cp .env.example .env.local

# App
NEXTAUTH_SECRET=replace_me
NEXTAUTH_URL=http://localhost:3000

# SurrealDB
SURREAL_HOST=ws://localhost:8000
SURREAL_USER=admin
SURREAL_PASSWORD=replace_me
SURREAL_NAMESPACE=bcsp
SURREAL_DATABASE=site

# Email (required for registration/email verification flows)
EMAIL_SERVICE=gmail
EMAIL_USER=replace_me
EMAIL_PASS=replace_me

# RouterAI (required for chat/RAG)
ROUTERAI_API_KEY=replace_me

# Optional: internal cron HTTP endpoint auth (production)
# CRON_SECRET=replace_me
