# ===========================================
# IT-Eco-For-SP — Переменные окружения
# ===========================================
# Скопируйте этот файл в .env.local и заполните значениями
# cp .env.example .env.local

# -------------------------------------------
# Порты (Docker)
# -------------------------------------------
# Порт для dev-режима (Docker). По умолчанию: 3000
DEV_PORT=3000
# Порт для production-режима (Docker). По умолчанию: 3000
APP_PORT=3000

# -------------------------------------------
# NextAuth (Аутентификация)
# -------------------------------------------
# Секретный ключ для сессий. Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_key_here_change_in_production
# URL приложения (должен совпадать с портом DEV_PORT или APP_PORT)
NEXTAUTH_URL=http://localhost:3000

# -------------------------------------------
# SurrealDB (База данных)
# -------------------------------------------
# Подключение через WebSocket или HTTP
SURREAL_HOST=ws://localhost:8000
# SURREAL_HOST=http://localhost:8000

# Учётные данные для подключения к БД
SURREAL_USER=admin
SURREAL_PASSWORD=your_secure_password_here

# Namespace и Database
SURREAL_NAMESPACE=bcsp
SURREAL_DATABASE=site

# -------------------------------------------
# RouterAI API (ИИ-ассистент)
# -------------------------------------------
ROUTERAI_API_KEY=your_routerai_api_key_here

# -------------------------------------------
# Email (Nodemailer)
# -------------------------------------------
# Для Gmail: создайте App Password в настройках Google Account
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# -------------------------------------------
# Codeforces API (опционально)
# -------------------------------------------
# API ключи для интеграции с Codeforces (если требуется)
CODEFORCES_API_KEY=

# -------------------------------------------
# AtCoder API (опционально)
# -------------------------------------------
# API ключи для интеграции с AtCoder (если требуется)
ATCODER_API_KEY=

# -------------------------------------------
# Режим приложения
# -------------------------------------------
NODE_ENV=development
